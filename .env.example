# Price Monitor — example environment variables.
# Copy this file to .env and fill in your values. Do not commit .env.

# TELEGRAM
TELEGRAM_TOKEN=
TELEGRAM_CHAT_IDS=

# ALERT SETTINGS
ALERT_THRESHOLD_PERCENT=1
ALERT_COOLDOWN_MINUTES=60
MAX_ALERT_CHANGE_PERCENT=100

# NOTIFICATIONS
SEND_RUN_SUMMARY=true
DRY_RUN=false

# OZON API
OZON_CLIENT_ID_1=
OZON_API_KEY_1=

OZON_CLIENT_ID_2=
OZON_API_KEY_2=

# WILDBERRIES (future)
WB_API_KEY_1=
