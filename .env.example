# Price Monitor — example environment variables.
# Copy this file to .env and fill in your values. Do not commit .env.

# TELEGRAM
TELEGRAM_TOKEN=
TELEGRAM_CHAT_IDS=

# ALERT SETTINGS
LAST_PRICE_ALERT_THRESHOLD_PERCENT=10
DAY_START_ALERT_THRESHOLD_PERCENT=20
ALERT_COOLDOWN_MINUTES=60
MAX_ALERT_CHANGE_PERCENT=100

# NOTIFICATIONS
SEND_TELEGRAM_ALERTS=true
SEND_EMAIL_ALERTS=false
SEND_STARTUP_MESSAGE=false
SEND_STARTUP_EMAIL=false
SEND_RUN_SUMMARY=true
SEND_DAILY_REPORT_EMAIL=false
DAILY_REPORT_TIME=23:05
DRY_RUN=false

# EMAIL
EMAIL_ENABLED=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_FROM=
EMAIL_TO=
EMAIL_SUBJECT_PREFIX=[Price Monitor]

# OZON API
OZON_CLIENT_ID_1=
OZON_API_KEY_1=

OZON_CLIENT_ID_2=
OZON_API_KEY_2=

# WILDBERRIES API
WB_API_KEY_1=
