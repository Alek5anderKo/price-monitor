# Price Monitor — example environment variables.
# Copy this file to .env and fill in your values. Do not commit .env.

# --- Telegram ---
# Bot token from @BotFather
TELEGRAM_TOKEN=your_telegram_bot_token
# Comma-separated chat IDs for alerts and notifications
TELEGRAM_CHAT_IDS=your_chat_id

# --- Alert thresholds (optional; defaults used if missing) ---
# Min price change % to trigger alert (default: 1)
ALERT_THRESHOLD_PERCENT=1
# Minutes before re-alerting same SKU/price (default: 60)
ALERT_COOLDOWN_MINUTES=60
# Do not alert if change exceeds this % (default: 100)
MAX_ALERT_CHANGE_PERCENT=100

# --- Notifications ---
# Send run summary to Telegram at end of run (default: false)
SEND_RUN_SUMMARY=false
# Future: optional startup message (not used yet)
# SEND_STARTUP_MESSAGE=true

# --- Ozon API (referenced by config/accounts.json via client_id_env / api_key_env) ---
OZON_CLIENT_ID_1=your_ozon_client_id
OZON_API_KEY_1=your_ozon_api_key
OZON_CLIENT_ID_2=your_ozon_client_id
OZON_API_KEY_2=your_ozon_api_key

# --- Wildberries (for future use; client not implemented yet) ---
# WB_API_KEY_1=your_wb_api_key
